# code_embedding workspace — environment template.
# Copy to .env (auto-loaded by cocoindex + main scripts): cp .env.example .env

# CocoIndex's own internal state store (LMDB) — tracks content fingerprints
# for incremental updates. Not the vector data; safe to delete to force a
# full reprocess (you'll lose memoization, not embeddings already in Postgres).
COCOINDEX_DB=./cocoindex.db

# Postgres + pgvector target. See README.md "Postgres / pgvector" section for
# the isolated Homebrew postgresql@17 setup this project expects on :5433.
POSTGRES_URL=postgres://cocoindex:cocoindex@localhost:5433/cocoindex

# Fallback to CPU for operations not supported by MPS on Mac.
# It's a no-op on other platforms.
PYTORCH_ENABLE_MPS_FALLBACK=1
